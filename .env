# Copy this file to .env before running docker compose.

APP_ENV=prod
APP_SECRET_KEY=change-this-secret-key
APP_ACCESS_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_BCRYPT_ROUNDS=12

MYSQL_ROOT_PASSWORD=root
MYSQL_ROOT_HOST=%
MYSQL_DATABASE=recipes_db
MYSQL_PORT=3308

# Docker compose icinde backend DATABASE_URL degeri docker-compose.yml icinde
# db servis adina gore otomatik olusturulur.

FRONTEND_PORT=5173
BACKEND_PORT=8000

# dummy = no ML model needed
# keras = uses the model paths below
IMAGE_RECOGNITION_MODE=keras
KERAS_MODEL_PATH=/app/vegetable-classification/merged_model.keras
KERAS_LABELS_PATH=/app/vegetable-classification/labels.txt
