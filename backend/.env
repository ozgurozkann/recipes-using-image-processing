# Backend
APP_ENV=dev
APP_SECRET_KEY=change-me-in-production
APP_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── MySQL ──────────────────────────────────────────────────────
# Format: mysql+pymysql://kullanici:sifre@host:port/veritabani?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:root@localhost:3308/recipes_db?charset=utf8mb4

# SQLite (geliştirme alternatifi):
# DATABASE_URL=sqlite:///./app.db

# PostgreSQL alternatifi:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/recipes
# ──────────────────────────────────────────────────────────────

# Password hashing
PASSWORD_BCRYPT_ROUNDS=12

# Image recognition: dummy | keras
IMAGE_RECOGNITION_MODE=keras
KERAS_MODEL_PATH=../vegetable-classification/merged_model.keras
KERAS_LABELS_PATH=../vegetable-classification/labels.txt

