# Backend
APP_ENV=dev
APP_SECRET_KEY=change-me
APP_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Use SQLite by default (dev). For Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/recipes
DATABASE_URL=sqlite:///./app.db

# Password hashing
PASSWORD_BCRYPT_ROUNDS=12

# Image recognition: dummy | keras
IMAGE_RECOGNITION_MODE=dummy
KERAS_MODEL_PATH=./vegetable-classification/vegetable_model.keras
KERAS_LABELS_PATH=./vegetable-classification/labels.txt

